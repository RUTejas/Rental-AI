# Copy to backend/.env for local development. Never commit production secrets.
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rentwise_ai?schema=public
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
MASTER_ADMIN_NAME=Master Administrator
MASTER_ADMIN_EMAIL=master@rentwise.ai
MASTER_ADMIN_PASSWORD=replace-before-first-deployment
CAPTCHA_SECRET=replace-with-a-long-random-secret
MAX_FILE_SIZE=52428800
